NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
HOSTNAME=127.0.0.1
PORT=3100
DATABASE_URL=file:/var/lib/pulsar/pulsar.db
SESSION_COOKIE_NAME=pulsar_session
SESSION_SECRET=generate-with-openssl-rand-hex-32
JOB_PAYLOAD_SECRET=generate-with-openssl-rand-hex-32
SESSION_TTL_DAYS=180
NEXT_PUBLIC_APP_URL=https://app.pulsar-cloud.space
PAYMENT_PROVIDER=PLATEGA
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_API_URL=https://app.platega.io
REMNAWAVE_BASE_URL=http://127.0.0.1:3000
REMNAWAVE_API_TOKEN=
REMNAWAVE_PROVIDER=HTTP
# Filled after provisioning Remnawave objects. These UUIDs are environment-specific.
REMNAWAVE_CONFIG_PROFILE_UUID=
REMNAWAVE_STANDARD_SQUAD_UUID=
REMNAWAVE_LTE_SQUAD_UUID=
REMNAWAVE_SUBSCRIPTION_TEMPLATE_UUID=
REMNAWAVE_HOST_FINGERPRINT=edge
REMNAWAVE_TRAFFIC_LIMIT_BYTES=0
REMNAWAVE_TRAFFIC_LIMIT_STRATEGY=NO_RESET
# Set only after Pulsar has a verified Remnawave webhook route.
REMNAWAVE_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
TELEGRAM_BOT_USERNAME=pulsarcloud_bot
RESEND_API_KEY=
EMAIL_FROM=Pulsar <auth@pulsar-cloud.space>
EMAIL_REPLY_TO=support@pulsar-cloud.space
