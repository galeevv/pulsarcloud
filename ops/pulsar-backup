#!/usr/bin/env bash
set -Eeuo pipefail

readonly source_db=/var/lib/pulsar/pulsar.db
readonly backup_dir=/var/backups/pulsar
readonly stamp="$(date -u +%Y%m%dT%H%M%SZ)"
readonly output="${backup_dir}/pulsar-${stamp}.db"

install -d -m 0700 "$backup_dir"
exec 9>"${backup_dir}/.backup.lock"
flock -n 9 || exit 0

test -s "$source_db"
sqlite3 "$source_db" ".timeout 10000" ".backup '${output}'"
test "$(sqlite3 "$output" 'PRAGMA integrity_check;')" = "ok"
gzip -9 "$output"
sha256sum "${output}.gz" >"${output}.gz.sha256"

find "$backup_dir" -maxdepth 1 -type f \
  \( -name 'pulsar-*.db.gz' -o -name 'pulsar-*.db.gz.sha256' \) \
  -mtime +14 -delete
