# Remnawave Node environment — template. Copy to `.env` (git-ignored) on each
# traffic node and paste the node certificate created in the panel:
#   Panel -> Nodes -> Create node -> copy the SSL_CERT value.
# Each node gets its OWN certificate. Never share one node's cert with another.

# Port the panel connects to. Must match the node record's port in the panel.
# Firewall restricts this to the panel IP only.
NODE_PORT=2222

# Panel secret (single line). Fetch from the panel: GET /api/keygen -> pubKey,
# or copy from the panel's node-install dialog. Same value for every node.
SECRET_KEY=CHANGE_ME
