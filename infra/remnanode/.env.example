# Remnawave Node environment — template. Copy to `.env` (git-ignored) on each
# traffic node and paste the node certificate created in the panel:
#   Panel -> Nodes -> Create node -> copy the SSL_CERT value.
# Each node gets its OWN certificate. Never share one node's cert with another.

# Admin/data port the panel connects to. Must match the port set on the node
# record in the panel. Firewall restricts this to the panel IP only.
APP_PORT=2222

# Node certificate issued by the panel (single line, starts with SSL_CERT=... in
# the panel copy dialog — paste only the value here).
SSL_CERT=CHANGE_ME
