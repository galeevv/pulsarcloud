# Yandex Cloud CDN / LTE (xHTTP) origin node — template.
# Copy to `.env` (git-ignored) on the origin server and fill real values.
# Do NOT commit the real .env. Do NOT leave any CHANGE_ME.

# Origin server public IP (the VPS nginx+Xray run on). Currently: pulsarnet.top.
# NOTE: DNS shows pulsarnet.top -> 144.31.156.25; the deployment brief wrote
# 144.31.156.254. Confirm the correct octet before use.
YANDEX_ORIGIN_IP=CHANGE_ME

# Origin domain — CDN connects here over HTTPS; Let's Encrypt cert lives here.
# DNS-only (no Cloudflare proxy). Example: origin.pulsarnet.top
YANDEX_ORIGIN_DOMAIN=CHANGE_ME

# CDN domain — the client connects here; CNAME to the Yandex GSLB target.
# DNS-only. Example: cdn.pulsarnet.top
YANDEX_CDN_DOMAIN=CHANGE_ME

# Xray xHTTP inbound — loopback only, fronted by nginx. Keep in sync with the
# Config Profile in the Remnawave panel.
XRAY_XHTTP_PORT=11443
XRAY_XHTTP_PATH=/poll

# Remnawave panel + node registration (paste the node certificate from the panel).
PANEL_URL=https://panel.pulsar-cloud.space
REMNAWAVE_NODE_CERT=CHANGE_ME
