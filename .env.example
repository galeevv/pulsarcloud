# Runtime
APP_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=file:./prisma/dev.db
LOG_LEVEL=info

# Auth and encryption (generate independent random values, 32+ bytes each)
SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_PEPPER=replace-with-at-least-32-random-characters
DATA_ENCRYPTION_KEY=replace-with-64-hex-characters

# Email (required when PULSAR_TEST_MODE=false)
RESEND_API_KEY=
RESEND_FROM_EMAIL='Pulsar <auth@pulsar-cloud.space>'

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Single administrator bootstrap
ADMIN_EMAIL=emil444158@gmail.com
ADMIN_TELEGRAM_ID=885112484
ADMIN_TELEGRAM_USERNAME=galeev66

# Payments: test or platega
PAYMENT_PROVIDER=test
BILLING_ENABLED=false
PAYMENT_WEBHOOK_SECRET=
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=

# Remnawave: local test mode uses mock; production uses the verified 2.8 HTTP API
REMNAWAVE_PROVIDER=mock
REMNAWAVE_BASE_URL=
REMNAWAVE_API_TOKEN=
REMNAWAVE_STANDARD_SQUAD_UUID=
REMNAWAVE_LTE_SQUAD_UUID=
REMNAWAVE_TIMEOUT_MS=8000

# Production override is dangerous and requires a local SQLite filename explicitly marked as test
# (test.db, *.test.db, test-*.db, or *-test.db); symlinks, URL parameters, and remote file URLs are rejected.
PULSAR_TEST_MODE=true
PULSAR_ALLOW_TEST_MODE_IN_PRODUCTION=false

# Worker
WORKER_POLL_INTERVAL_MS=1500
WORKER_LEASE_MS=60000
WORKER_BATCH_SIZE=10
