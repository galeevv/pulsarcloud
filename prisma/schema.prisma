generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuthProvider {
  EMAIL
  TELEGRAM
}

enum AuthChallengeKind {
  EMAIL_OTP
  MAGIC_LINK
  TELEGRAM_LOGIN
}

enum AuthChallengeStatus {
  PENDING
  CONSUMED
  EXPIRED
  CANCELED
}

enum PricingVersionStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum PriceQuotePurpose {
  SUBSCRIPTION
}

enum Currency {
  RUB
}

enum PaymentProvider {
  MOCK
  PLATEGA
}

enum PaymentStatus {
  CREATED
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum SubscriptionStatus {
  NONE
  TRIAL
  ACTIVE
  EXPIRED
  CANCELED
}

enum SubscriptionSyncStatus {
  NOT_SYNCED
  PENDING
  SYNCED
  FAILED
}

enum ReferralInviteStatus {
  REGISTERED
  CONVERTED
  CANCELED
}

enum ReferralRewardStatus {
  PENDING
  AVAILABLE
  RESERVED
  PAID
  CANCELED
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

enum WalletLedgerType {
  PAYMENT_CAPTURE
  PAYMENT_REFUND
  SUBSCRIPTION_CHARGE
  REFERRAL_REWARD
  PAYOUT_RESERVE
  PAYOUT_RELEASE
  ADMIN_ADJUSTMENT
}

enum WalletLedgerStatus {
  PENDING
  POSTED
  VOIDED
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELED
}

enum SupportConversationStatus {
  OPEN
  CLOSED
}

enum SupportMessageAuthorRole {
  USER
  ADMIN
  SYSTEM
}

enum TelegramUpdateStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum JobType {
  SEND_AUTH_EMAIL
  SEND_PAYMENT_RECEIPT
  PROCESS_PAYMENT_WEBHOOK
  PROVISION_SUBSCRIPTION
  SYNC_SUBSCRIPTION
  PROCESS_TELEGRAM_UPDATE
  EXPIRE_AUTH_CHALLENGES
  DELETE_EXPIRED_SESSIONS
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum NodeType {
  REGULAR
  LTE
  GAMING
}

enum NodeProtocol {
  VLESS_REALITY
  HYSTERIA
  VLESS_XHTTP_TLS
}

enum NodeStatus {
  ACTIVE
  MAINTENANCE
  DISABLED
}

model User {
  id         String     @id @default(cuid())
  role       UserRole   @default(USER)
  status     UserStatus @default(ACTIVE)
  balanceRub Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  authIdentities       AuthIdentity[]
  authChallenges       AuthChallenge[]
  sessions             Session[]
  priceQuotes          PriceQuote[]
  payments             Payment[]
  subscription         Subscription?
  referralProfile      ReferralProfile?
  referralInvitesSent  ReferralInvite[]      @relation("ReferralInviteInviter")
  referralInvite       ReferralInvite?       @relation("ReferralInviteInvited")
  referralRewards      ReferralReward[]       @relation("ReferralRewardOwner")
  referralConversions  ReferralReward[]       @relation("ReferralRewardInvited")
  walletLedgerEntries  WalletLedgerEntry[]
  payoutRequests       PayoutRequest[]        @relation("PayoutOwner")
  approvedPayouts      PayoutRequest[]        @relation("PayoutApprovedBy")
  paidPayouts          PayoutRequest[]        @relation("PayoutPaidBy")
  rejectedPayouts      PayoutRequest[]        @relation("PayoutRejectedBy")
  supportConversations SupportConversation[]
  supportMessages      SupportMessage[]
  auditEvents          AuditEvent[]           @relation("AuditActor")

  @@index([role, status])
  @@index([createdAt])
}

model AuthIdentity {
  id              String       @id @default(cuid())
  userId          String
  provider        AuthProvider
  providerSubject String
  verifiedAt      DateTime?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
}

model AuthChallenge {
  id              String              @id @default(cuid())
  userId          String?
  provider        AuthProvider
  providerSubject String
  kind            AuthChallengeKind
  status          AuthChallengeStatus @default(PENDING)
  tokenHash       String              @unique
  codeHash        String?
  attemptCount    Int                 @default(0)
  maxAttempts     Int                 @default(5)
  expiresAt       DateTime
  consumedAt      DateTime?
  context         Json?
  createdAt       DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider, providerSubject, status, createdAt])
  @@index([status, expiresAt])
  @@index([userId])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model PricingVersion {
  id                         String               @id @default(cuid())
  version                    Int                  @unique
  status                     PricingVersionStatus @default(DRAFT)
  currency                   Currency             @default(RUB)
  baseMonthlyPriceRub        Int
  extraDeviceMonthlyPriceRub Int
  minDeviceLimit             Int                  @default(1)
  maxDeviceLimit             Int                  @default(5)
  lteMonthlyPriceRub         Int
  durationDiscounts          Json
  referralFriendDiscountPct  Int                  @default(0)
  referralRewardRub          Int
  minimalPayoutRub           Int
  effectiveAt                DateTime?
  retiredAt                  DateTime?
  createdAt                  DateTime             @default(now())

  quotes PriceQuote[]

  @@index([status, effectiveAt])
}

model PriceQuote {
  id                    String            @id @default(cuid())
  userId                String
  pricingVersionId      String
  purpose               PriceQuotePurpose @default(SUBSCRIPTION)
  currency              Currency          @default(RUB)
  durationMonths        Int
  deviceLimit           Int
  lteEnabled            Boolean           @default(false)
  referralDiscountPct   Int               @default(0)
  subtotalRub           Int
  discountRub           Int
  totalRub              Int
  pricingSnapshot       Json
  idempotencyKey        String            @unique
  expiresAt             DateTime
  consumedAt            DateTime?
  createdAt             DateTime          @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  pricingVersion PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Restrict)
  payment        Payment?

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  quoteId           String          @unique
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  currency          Currency        @default(RUB)
  amountRub         Int
  durationMonths    Int
  deviceLimit       Int
  lteEnabled        Boolean         @default(false)
  idempotencyKey    String          @unique
  externalPaymentId String?
  checkoutUrl       String?
  metadata          Json?
  refundedAmountRub Int             @default(0)
  confirmedAt       DateTime?
  refundedAt        DateTime?
  canceledAt        DateTime?
  failedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  quote         PriceQuote            @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  webhookEvents PaymentWebhookEvent[]
  periods       SubscriptionPeriod[]
  referralReward ReferralReward?
  ledgerEntries WalletLedgerEntry[]

  @@unique([provider, externalPaymentId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model PaymentWebhookEvent {
  id              String                  @id @default(cuid())
  provider        PaymentProvider
  providerEventId String
  eventType       String
  paymentId       String?
  payloadHash     String
  payload         Json
  status          WebhookProcessingStatus @default(RECEIVED)
  attemptCount    Int                     @default(0)
  processedAt     DateTime?
  lastError       String?
  verifiedAt      DateTime?
  receivedAt      DateTime                @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@unique([provider, payloadHash])
  @@index([paymentId])
  @@index([status, receivedAt])
}

model Subscription {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  status                SubscriptionStatus     @default(NONE)
  startsAt              DateTime?
  expiresAt             DateTime?
  deviceLimit           Int                    @default(1)
  lteEnabled            Boolean                @default(false)
  subscriptionUrl       String?
  remnawaveUserId       String?                @unique
  syncStatus            SubscriptionSyncStatus @default(NOT_SYNCED)
  lastUserFriendlyError String?
  lastTechnicalError    String?
  version               Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  periods SubscriptionPeriod[]

  @@index([status, expiresAt])
  @@index([syncStatus, updatedAt])
}

model SubscriptionPeriod {
  id             String   @id @default(cuid())
  subscriptionId String
  paymentId      String?  @unique
  startsAt       DateTime
  endsAt         DateTime
  deviceLimit    Int
  lteEnabled     Boolean  @default(false)
  amountRub      Int
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([subscriptionId, startsAt])
  @@index([endsAt])
}

model ReferralProfile {
  userId     String   @id
  inviteCode String   @unique
  isEnabled  Boolean  @default(false)
  enabledAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isEnabled])
}

model ReferralInvite {
  id                 String               @id @default(cuid())
  inviterId          String
  invitedUserId      String               @unique
  inviteCodeSnapshot String
  status             ReferralInviteStatus @default(REGISTERED)
  createdAt          DateTime             @default(now())
  convertedAt        DateTime?
  canceledAt         DateTime?

  inviter User            @relation("ReferralInviteInviter", fields: [inviterId], references: [id], onDelete: Restrict)
  invited User            @relation("ReferralInviteInvited", fields: [invitedUserId], references: [id], onDelete: Restrict)
  reward  ReferralReward?

  @@index([inviterId, status])
  @@index([status, createdAt])
}

model ReferralReward {
  id            String               @id @default(cuid())
  inviteId      String               @unique
  inviterId     String
  invitedUserId String
  paymentId     String               @unique
  amountRub     Int
  status        ReferralRewardStatus @default(PENDING)
  availableAt   DateTime?
  reservedAt    DateTime?
  paidAt        DateTime?
  canceledAt    DateTime?
  createdAt     DateTime             @default(now())

  invite  ReferralInvite @relation(fields: [inviteId], references: [id], onDelete: Restrict)
  inviter User           @relation("ReferralRewardOwner", fields: [inviterId], references: [id], onDelete: Restrict)
  invited User           @relation("ReferralRewardInvited", fields: [invitedUserId], references: [id], onDelete: Restrict)
  payment Payment        @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  ledgerEntry WalletLedgerEntry?

  @@index([inviterId, status])
  @@index([invitedUserId])
}

model WalletLedgerEntry {
  id             String                @id @default(cuid())
  userId         String
  direction      WalletLedgerDirection
  amountRub      Int
  currency       Currency              @default(RUB)
  type           WalletLedgerType
  status         WalletLedgerStatus    @default(POSTED)
  idempotencyKey String                @unique
  paymentId      String?
  payoutRequestId String?
  referralRewardId String?             @unique
  metadata       Json?
  createdAt      DateTime              @default(now())
  postedAt       DateTime?
  voidedAt       DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  payment        Payment?        @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  payoutRequest  PayoutRequest?  @relation(fields: [payoutRequestId], references: [id], onDelete: Restrict)
  referralReward ReferralReward? @relation(fields: [referralRewardId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([paymentId])
  @@index([payoutRequestId])
  @@index([status, createdAt])
}

model PayoutRequest {
  id             String              @id @default(cuid())
  userId         String
  amountRub      Int
  currency       Currency            @default(RUB)
  status         PayoutRequestStatus @default(PENDING)
  payoutDetails  String
  idempotencyKey String              @unique
  adminNote      String?
  approvedById   String?
  paidById       String?
  rejectedById   String?
  createdAt      DateTime            @default(now())
  approvedAt     DateTime?
  paidAt         DateTime?
  rejectedAt     DateTime?
  canceledAt     DateTime?

  user       User  @relation("PayoutOwner", fields: [userId], references: [id], onDelete: Restrict)
  approvedBy User? @relation("PayoutApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  paidBy     User? @relation("PayoutPaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  rejectedBy User? @relation("PayoutRejectedBy", fields: [rejectedById], references: [id], onDelete: SetNull)
  ledgerEntries WalletLedgerEntry[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportConversation {
  id            String                    @id @default(cuid())
  userId        String
  status        SupportConversationStatus @default(OPEN)
  subject       String?
  lastMessageAt DateTime?
  closedAt      DateTime?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages SupportMessage[]

  @@index([userId, status, updatedAt])
  @@index([status, lastMessageAt])
}

model SupportMessage {
  id             String                   @id @default(cuid())
  conversationId String
  senderId       String?
  authorRole     SupportMessageAuthorRole
  body           String
  idempotencyKey String?                  @unique
  createdAt      DateTime                 @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?               @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model TelegramUpdate {
  id           String               @id @default(cuid())
  updateId     BigInt               @unique
  status       TelegramUpdateStatus @default(RECEIVED)
  payload      Json
  payloadHash  String               @unique
  attemptCount Int                  @default(0)
  receivedAt   DateTime             @default(now())
  processedAt  DateTime?
  lastError    String?

  @@index([status, receivedAt])
}

model Job {
  id             String    @id @default(cuid())
  type           JobType
  status         JobStatus @default(PENDING)
  idempotencyKey String    @unique
  payload        Json
  attemptCount   Int       @default(0)
  maxAttempts    Int       @default(5)
  runAt          DateTime  @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  lastError      String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, runAt])
  @@index([lockedAt])
  @@index([type, status])
}

model AuditEvent {
  id             String   @id @default(cuid())
  actorUserId    String?
  eventType      String
  entityType     String
  entityId       String?
  idempotencyKey String?  @unique
  data           Json?
  createdAt      DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([eventType, createdAt])
  @@index([entityType, entityId, createdAt])
}

model Node {
  id        String       @id @default(cuid())
  name      String
  country   String
  city      String
  type      NodeType
  protocol  NodeProtocol
  domain    String       @unique
  status    NodeStatus   @default(ACTIVE)
  capacity  Int
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([type, status])
  @@index([sortOrder])
}
